# Production Environment Configuration
# Copy this to .env and fill in the actual values

# ============================================
# Domain Configuration
# ============================================
DOMAIN_NAME=your-domain.com
GRAFANA_DOMAIN=grafana.your-domain.com
PORTAINER_DOMAIN=portainer.your-domain.com
STATUS_DOMAIN=status.your-domain.com

# ============================================
# Security
# ============================================
# Generate with: openssl rand -base64 32
GF_ADMIN_PASSWORD=changeme-admin-password

# ============================================
# SSL/TLS (Let's Encrypt)
# ============================================
# Email untuk Let's Encrypt notifications
LETSENCRYPT_EMAIL=your-email@example.com

# ============================================
# Timezone
# ============================================
TZ=UTC

# ============================================
# Backup & Data Retention
# ============================================
PROMETHEUS_RETENTION_DAYS=30
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM UTC
